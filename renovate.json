{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":maintainLockFilesWeekly"
  ],
  "minimumReleaseAge": "10 days",
  "internalChecksFilter": "strict",
  "labels": ["dependencies"],
  "prConcurrentLimit": 10,
  "vulnerabilityAlerts": {
    "labels": ["security", "fast-track"],
    "minimumReleaseAge": "0 days",
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "commitMessagePrefix": "ci:",
      "addLabels": ["ci"],
      "groupName": "ci-actions"
    },
    {
      "matchManagers": ["dockerfile", "docker-compose"],
      "pinDigests": true,
      "commitMessagePrefix": "deps:",
      "addLabels": ["docker"],
      "groupName": "docker-base-images"
    },
    {
      "matchManagers": ["kubernetes", "helm-values", "helmv3"],
      "pinDigests": true,
      "commitMessagePrefix": "deps:",
      "addLabels": ["k8s"],
      "groupName": "k8s-images"
    },
    {
      "matchManagers": ["gomod"],
      "commitMessagePrefix": "deps:",
      "groupName": "go-deps"
    },
    {
      "matchManagers": ["pip_requirements"],
      "matchFileNames": ["testdata/python_verifier_fixture/**"],
      "commitMessagePrefix": "deps:",
      "addLabels": ["python"],
      "groupName": "verifier-fixture"
    },
    {
      "matchManagers": ["pip_requirements"],
      "matchFileNames": [".github/**"],
      "commitMessagePrefix": "deps:",
      "addLabels": ["python"],
      "groupName": "pr-review-deps"
    },
    {
      "matchManagers": ["npm"],
      "matchFileNames": ["sdk/verifiers/ts/**"],
      "commitMessagePrefix": "deps:",
      "addLabels": ["javascript"],
      "groupName": "ts-verifier"
    },
    {
      "matchManagers": ["cargo"],
      "matchFileNames": ["sdk/verifiers/rust/**"],
      "commitMessagePrefix": "deps:",
      "addLabels": ["rust"],
      "groupName": "rust-verifier"
    },
    {
      "matchManagers": ["pre-commit"],
      "commitMessagePrefix": "ci:",
      "addLabels": ["ci"],
      "groupName": "pre-commit-hooks"
    },
    {
      "matchUpdateTypes": ["major"],
      "addLabels": ["major-update", "needs-review"],
      "automerge": false
    },
    {
      "description": "Hold TypeScript at 5.x in the verifier. TS 6.0 needs tsconfig and source migrations we have not scoped.",
      "matchManagers": ["npm"],
      "matchFileNames": ["sdk/verifiers/ts/**"],
      "matchPackageNames": ["typescript"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    },
    {
      "description": "Hold jsonschema at 0.18.x in the Rust verifier. 0.19+ renames JSONSchema to Validator and changes the compile/validate API, needs manual migration.",
      "matchManagers": ["cargo"],
      "matchFileNames": ["sdk/verifiers/rust/**"],
      "matchPackageNames": ["jsonschema"],
      "allowedVersions": "<0.19"
    }
  ]
}
